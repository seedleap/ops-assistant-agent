# Local development template. Copy to .env and replace placeholders locally.
NODE_ENV=development
LOG_LEVEL=info
HOST=127.0.0.1
PORT=8010
DATA_DIR=./data
STATIC_UI_ENABLED=true
API_AUTH_MODE=none
CORS_ORIGINS=*
SCHEDULER_ENABLED=false

# Real Pi Agent runtime (set true only for offline UI/API smoke tests).
ASSISTANT_DRY_RUN=false
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-service-account.json

# Idea workflow model. Defaults are shown explicitly for deployment clarity.
IDEA_MODEL_PROVIDER=google-vertex
IDEA_MODEL_ID=gemini-3-flash-preview
IDEA_THINKING_LEVEL=high
IDEA_TIMEOUT_MS=120000

# Image generation. AZURE_IMAGE_* remains supported for compatibility.
IDEA_IMAGE_BASE_URL=https://your-azure-resource.openai.azure.com
IDEA_IMAGE_API_KEY=replace-locally
IDEA_IMAGE_MODEL=gpt-image-1.5
IDEA_IMAGE_QUALITY=low
IDEA_IMAGE_TIMEOUT_MS=90000

IDEA_ASSET_STORAGE=local

# Langfuse. Keep disabled until valid credentials are supplied.
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://your-langfuse.example.com
LANGFUSE_PUBLIC_KEY=replace-locally
LANGFUSE_SECRET_KEY=replace-locally
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=local

# Optional remote integrations.
OPS_MCP_URL=https://your-ops-mcp.example.com/mcp
OPS_MCP_TOKEN=replace-locally
REMOTE_SKILLS_ENABLED=false
CONVERSATION_ARCHIVE_ENABLED=false
