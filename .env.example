NODE_ENV=development
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8010
CORS_ORIGINS=*
TRUST_PROXY_HOPS=0
STATIC_UI_ENABLED=true
# 开发默认不鉴权；生产默认 jwt，必须配置至少 32 字符的随机 secret。
API_AUTH_MODE=none
API_JWT_SECRET=
API_JWT_ISSUER=
API_JWT_AUDIENCE=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
DATA_DIR=./data
SCHEDULER_ENABLED=true
SCHEDULER_POLL_MS=60000
DEFAULT_OUTREACH_SILENT_MINUTES=60
INTERACTIVE_SESSION_TIMEOUT_MINUTES=60

# 模型配置。本地只验证页面、接口和调度链路时，可以设成 true，不调用真实模型。
ASSISTANT_DRY_RUN=false
ASSISTANT_MODEL_PROVIDER=google-vertex
ASSISTANT_MODEL_ID=gemini-3-flash-preview
ASSISTANT_THINKING_LEVEL=low
ASSISTANT_TEMPERATURE=0.3
ASSISTANT_MAX_TURNS=10
ASSISTANT_TIMEOUT_MS=120000

# 主动触达可以独立选择更轻量的模型和参数；默认复用对话模型。
OUTREACH_MODEL_PROVIDER=google-vertex
OUTREACH_MODEL_ID=gemini-3-flash-preview
OUTREACH_THINKING_LEVEL=off
OUTREACH_TEMPERATURE=0.2
OUTREACH_MAX_TURNS=6
OUTREACH_TIMEOUT_MS=90000

# 生产可选模型白名单，使用 provider/model-id，逗号分隔。
MODEL_WHITELIST=google-vertex/gemini-3-flash-preview,google-vertex/gemini-3.1-flash-lite

# Langfuse trace。启用时必须同时配置 public key 和 secret key。
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=

# Vertex / Gemini 凭据配置。凭据文件只放在本项目 config/ 目录，不提交。
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# 智能体可读取的知识库目录。
SKILLS_DIR=./skills

# IM 前端静态页面目录（http://localhost:8010/ 打开）。
PUBLIC_DIR=./public

# 真实作品数据查询。
# OPS_SQL_GATEWAY_URL：HTTP 只读 SQL 网关地址，接收 {"sql":"...", "timeoutMs":120000}。
# OPS_SQL_GATEWAY_TOKEN：可选，用 Bearer token 传给 HTTP 网关。
# OPS_SQL_GATEWAY_CMD：可选，本项目自己的网关命令；从 stdin 读取同样的 JSON，stdout 输出查询结果 JSON。
PYTHON_BIN=python3
OPS_QUERY_SCRIPT=./scripts/ops_query.py
OPS_SQL_GATEWAY_URL=
OPS_SQL_GATEWAY_TOKEN=
OPS_SQL_GATEWAY_CMD=

# 本地样例数据，仅供 /data/query 调试端点使用。
LOOPIT_DATA_FILE=./sample-data/loopit-data.json
