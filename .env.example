PORT=8010
DATA_DIR=./data
SCHEDULER_POLL_MS=60000
DEFAULT_OUTREACH_SILENT_MINUTES=60
INTERACTIVE_SESSION_TIMEOUT_MINUTES=60

# 模型配置。本地只验证页面、接口和调度链路时，可以设成 true，不调用真实模型。
ASSISTANT_DRY_RUN=false
ASSISTANT_MODEL_PROVIDER=google-vertex
ASSISTANT_MODEL_ID=gemini-3-flash-preview

# Vertex / Gemini 凭据配置。凭据文件只放在本项目 config/ 目录，不提交。
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
GOOGLE_CLOUD_PROJECT=seedleap
GOOGLE_CLOUD_LOCATION=global
GCLOUD_PROJECT=seedleap
GCLOUD_PROJECT_ID=seedleap
GCLOUD_LOCATION=global

# 智能体可读取的知识库目录。
SKILLS_DIR=./skills

# IM 前端静态页面目录（http://localhost:8010/ 打开）。
PUBLIC_DIR=./public

# 真实作品数据查询。
# OPS_SQL_GATEWAY_URL：HTTP 只读 SQL 网关地址，接收 {"sql":"...", "timeoutMs":120000}。
# OPS_SQL_GATEWAY_TOKEN：可选，用 Bearer token 传给 HTTP 网关。
# OPS_SQL_GATEWAY_CMD：可选，本项目自己的网关命令；从 stdin 读取同样的 JSON，stdout 输出查询结果 JSON。
PYTHON_BIN=python3
OPS_QUERY_SCRIPT=./scripts/ops_query.py
OPS_SQL_GATEWAY_URL=
OPS_SQL_GATEWAY_TOKEN=
OPS_SQL_GATEWAY_CMD=

# 本地样例数据，仅供 /data/query 调试端点使用。
OPS_DATA_FILE=./sample-data/metrics.json
LOOPIT_DATA_FILE=./sample-data/loopit-data.json
