{
  "name": "ops-assistant-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "protobufjs"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "tsx watch src/main.ts",
    "dev:once": "tsx src/main.ts",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/main.js",
    "check": "pnpm run typecheck && pnpm test && pnpm run build",
    "query": "python3 scripts/ops_query.py",
    "query:data": "tsx src/loopitDataCli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@langfuse/otel": "5.9.1",
    "@langfuse/tracing": "5.9.1",
    "@opentelemetry/sdk-node": "0.220.0",
    "@sinclair/typebox": "0.34.49",
    "async-mutex": "0.5.0",
    "cors": "2.8.6",
    "dotenv": "16.6.1",
    "express": "5.2.1",
    "express-jwt": "8.5.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.3.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.20.0",
    "@types/supertest": "7.2.0",
    "jose": "6.2.3",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
