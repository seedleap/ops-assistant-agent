# Production template. Inject all secret values through the deployment secret manager.
NODE_ENV=production
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8010
DATA_DIR=/app/data
STATIC_UI_ENABLED=false
CORS_ORIGINS=https://ops.loopit.example
TRUST_PROXY_HOPS=1
API_AUTH_MODE=jwt
API_JWT_SECRET=replace-with-at-least-32-random-characters
API_JWT_ISSUER=https://auth.loopit.example
API_JWT_AUDIENCE=ops-assistant-agent
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
SCHEDULER_ENABLED=true

ASSISTANT_DRY_RUN=false
GOOGLE_CLOUD_PROJECT=your-production-gcp-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-service-account.json

AZURE_OPENAI_API_KEY=inject-from-secret-manager
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=v1
IDEA_THINKING_LEVEL=high
IDEA_TIMEOUT_MS=120000

IDEA_IMAGE_BASE_URL=https://your-azure-resource.openai.azure.com
IDEA_IMAGE_API_KEY=inject-from-secret-manager
IDEA_IMAGE_MODEL=gpt-image-1.5
IDEA_IMAGE_QUALITY=low
IDEA_IMAGE_TIMEOUT_MS=90000

# S3 objects should remain private behind the configured CDN.
IDEA_ASSET_STORAGE=s3
# Optional; defaults to Carmack's production public-image bucket.
# USER_PUBLIC_IMAGES_BUCKET=user-public-images-829115578968

LANGFUSE_ENABLED=true
LANGFUSE_BASE_URL=https://your-langfuse.example.com
LANGFUSE_PUBLIC_KEY=inject-from-secret-manager
LANGFUSE_SECRET_KEY=inject-from-secret-manager
LANGFUSE_TRACING_ENVIRONMENT=production
LANGFUSE_RELEASE=replace-with-deployment-sha

# Required by the live production agent configuration.
OPS_MCP_URL=https://your-ops-mcp.example.com/mcp
OPS_MCP_TOKEN=inject-from-secret-manager
OPS_MCP_TIMEOUT_MS=120000
REMOTE_SKILLS_ENABLED=false
CONVERSATION_ARCHIVE_ENABLED=false
