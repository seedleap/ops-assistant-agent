NODE_ENV=production
LOG_LEVEL=info

# Internal gateway / service-to-service authentication.
API_AUTH_MODE=jwt
API_JWT_SECRET=replace-me
API_JWT_ISSUER=
API_JWT_AUDIENCE=
CORS_ORIGINS=https://replace-with-ops-console.example.com
TRUST_PROXY_HOPS=1
STATIC_UI_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Single-instance MVP runtime.
SCHEDULER_ENABLED=true
SCHEDULER_POLL_MS=60000
DEFAULT_OUTREACH_SILENT_MINUTES=60
INTERACTIVE_SESSION_TIMEOUT_MINUTES=60

# Deploy-time overrides for versioned defaults in src/agent/profiles/.
ASSISTANT_DRY_RUN=false
ASSISTANT_MODEL_PROVIDER=google-vertex
ASSISTANT_MODEL_ID=gemini-3-flash-preview
ASSISTANT_THINKING_LEVEL=low
ASSISTANT_TEMPERATURE=0.3
ASSISTANT_MAX_TURNS=10
ASSISTANT_TIMEOUT_MS=120000
OUTREACH_MODEL_PROVIDER=google-vertex
OUTREACH_MODEL_ID=gemini-3-flash-preview
OUTREACH_THINKING_LEVEL=off
OUTREACH_TEMPERATURE=0.2
OUTREACH_MAX_TURNS=6
OUTREACH_TIMEOUT_MS=90000
MODEL_WHITELIST=google-vertex/gemini-3-flash-preview,google-vertex/gemini-3.1-flash-lite

# Vertex credentials JSON is mounted separately by Compose/Kubernetes.
GOOGLE_CLOUD_PROJECT=replace-with-gcp-project
GOOGLE_CLOUD_LOCATION=global

# Langfuse.
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=replace-with-public-key
LANGFUSE_SECRET_KEY=replace-with-secret-key
LANGFUSE_BASE_URL=https://replace-with-langfuse-host
LANGFUSE_TRACING_ENVIRONMENT=production
LANGFUSE_RELEASE=replace-with-image-sha

# Remote Loopit data MCP service (Streamable HTTP).
OPS_MCP_URL=https://replace-with-ops-data-service/mcp
OPS_MCP_TOKEN=replace-with-service-token
OPS_MCP_TIMEOUT_MS=120000
OPS_MCP_MAX_RESPONSE_BYTES=2097152
