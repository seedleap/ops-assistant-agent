#!/usr/bin/env sh
# 运营数据查询 CLI：按 UID / PID 查真实作品数据（消费 / 评论 / prompt / 画像 / 作品列表）。
# 底层走 loopit-data-ops gateway → 阿里云 MaxCompute。
#
# 示例：
#   ./bin/ops-query overview     --pid <PID> --days 7 --pretty
#   ./bin/ops-query consumption  --pid <PID> --days 7
#   ./bin/ops-query comments     --pid <PID> --sort hot --limit 100
#   ./bin/ops-query prompt       --pid <PID> --rounds 5
#   ./bin/ops-query works        --uid <UID> --public
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"

exec "${PYTHON_BIN}" "${PROJECT_ROOT}/scripts/ops_query.py" "$@"
